# ─────────────────────────────────────────────────────────────
# Contact Form — SMTP Configuration
# ─────────────────────────────────────────────────────────────
# Copy this file to `.env.local` and fill in your values:
#   cp .env.example .env.local
#
# Restart the dev server after changing env vars:
#   npm run dev
# ─────────────────────────────────────────────────────────────

# SMTP server hostname (examples below)
SMTP_HOST=smtp.gmail.com

# SMTP port — use 587 for STARTTLS, 465 for SSL
SMTP_PORT=587

# SMTP login username (usually your full email address)
SMTP_USER=your-email@gmail.com

# SMTP password or app-specific password
# Gmail: create an App Password at https://myaccount.google.com/apppasswords
SMTP_PASS=your-app-password

# "From" address shown in the inbox (must be allowed by your SMTP provider)
SMTP_FROM="Think Beyond Agency <hello@thinkbeyondagency.com>"

# Where contact form submissions are delivered
CONTACT_EMAIL=hello@thinkbeyondagency.com

# ─────────────────────────────────────────────────────────────
# Provider quick reference
# ─────────────────────────────────────────────────────────────
#
# Gmail
#   SMTP_HOST=smtp.gmail.com
#   SMTP_PORT=587
#   Use an App Password (2FA required)
#
# Outlook / Microsoft 365
#   SMTP_HOST=smtp.office365.com
#   SMTP_PORT=587
#
# Zoho Mail
#   SMTP_HOST=smtp.zoho.com
#   SMTP_PORT=587
#
# SendGrid (SMTP relay)
#   SMTP_HOST=smtp.sendgrid.net
#   SMTP_PORT=587
#   SMTP_USER=apikey
#   SMTP_PASS=<your SendGrid API key>
#
# Mailgun
#   SMTP_HOST=smtp.mailgun.org
#   SMTP_PORT=587
# ─────────────────────────────────────────────────────────────
